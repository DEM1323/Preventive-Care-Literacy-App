# Google Apps Script Web App URL (deploy Code.gs as Web App)
VITE_GAS_SUBMIT_URL=

# Shared execution token — must match EXECUTION_TOKEN in Apps Script
VITE_GAS_EXECUTION_TOKEN=

# Published Google Sheet JSON endpoint for module CMS
VITE_MODULES_SHEET_URL=

# Symmetric encryption passcode — used client-side; nurses enter locally to decrypt
VITE_DISTRICT_ENCRYPTION_PASSCODE=district-default-key

# Nurse dashboard gate passcode (session-only access to /nurse route)
VITE_NURSE_DASHBOARD_PASSCODE=nurse123

# GitHub Pages base path (set to /repo-name/ for production deploy)
# VITE_BASE_PATH=/Preventive-Care-Literacy-App/
